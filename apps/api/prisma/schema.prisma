// ============================================================
// Универсальная мастерская файлов — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  USER
  ADMIN
}

enum JobStatus {
  QUEUED
  PROCESSING
  DONE
  ERROR
  CANCELED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
}

// ============================================================
// USERS — пользователи системы
// ============================================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  name          String?   @db.VarChar(100)
  role          UserRole  @default(USER)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // Связи
  sessions      UserSession[]
  fileJobs      FileJob[]
  auditLogs     AuditLog[]
  subscriptions UserSubscription[]

  @@map("users")
}

// ============================================================
// USER_SESSIONS — сессии с refresh token
// ============================================================

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash") @db.VarChar(255)
  ipAddress        String?   @map("ip_address") @db.VarChar(45)
  userAgent        String?   @map("user_agent") @db.VarChar(512)
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  revokedAt        DateTime? @map("revoked_at")

  // Связи
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

// ============================================================
// FILE_JOBS — задачи на обработку файлов
// ============================================================

model FileJob {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String?   @map("user_id") @db.Uuid
  originalFilename   String    @map("original_filename") @db.VarChar(255)
  storedOriginalPath String    @map("stored_original_path") @db.VarChar(500)
  outputFilename     String?   @map("output_filename") @db.VarChar(255)
  storedOutputPath   String?   @map("stored_output_path") @db.VarChar(500)
  mimeType           String    @map("mime_type") @db.VarChar(127)
  fileSizeBefore     BigInt    @map("file_size_before")
  fileSizeAfter      BigInt?   @map("file_size_after")
  operationType      String    @map("operation_type") @db.VarChar(100)
  sourceFormat       String    @map("source_format") @db.VarChar(20)
  targetFormat       String?   @map("target_format") @db.VarChar(20)
  status             JobStatus @default(QUEUED)
  errorMessage       String?   @map("error_message") @db.Text
  retryCount         Int       @default(0) @map("retry_count")
  maxRetries         Int       @default(3) @map("max_retries")
  priority           Int       @default(0)
  lockedAt           DateTime? @map("locked_at")
  lockedBy           String?   @map("locked_by") @db.VarChar(100)
  createdAt          DateTime  @default(now()) @map("created_at")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  expiresAt          DateTime? @map("expires_at")
  deletedAt          DateTime? @map("deleted_at")

  // Связи
  user    User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  options JobOption[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@index([status, priority, createdAt], map: "idx_worker_polling")
  @@index([expiresAt])
  @@index([deletedAt])
  @@map("file_jobs")
}

// ============================================================
// JOB_OPTIONS — параметры задачи (key-value)
// ============================================================

model JobOption {
  id         String @id @default(uuid()) @db.Uuid
  fileJobId  String @map("file_job_id") @db.Uuid
  optionKey  String @map("option_key") @db.VarChar(100)
  optionValue String @map("option_value") @db.VarChar(1000)

  // Связи
  fileJob FileJob @relation(fields: [fileJobId], references: [id], onDelete: Cascade)

  @@index([fileJobId])
  @@map("job_options")
}

// ============================================================
// AUDIT_LOGS — журнал действий
// ============================================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // Связи
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// BILLING_PLANS — тарифные планы (future-ready)
// ============================================================

model BillingPlan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(50)
  slug         String   @unique @db.VarChar(50)
  description  String?  @db.Text
  priceMonthly Int      @default(0) @map("price_monthly")
  priceYearly  Int      @default(0) @map("price_yearly")
  limits       Json     @default("{}")
  features     Json     @default("[]")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Связи
  subscriptions UserSubscription[]

  @@map("billing_plans")
}

// ============================================================
// USER_SUBSCRIPTIONS — подписки пользователей (future-ready)
// ============================================================

model UserSubscription {
  id         String             @id @default(uuid()) @db.Uuid
  userId     String             @map("user_id") @db.Uuid
  planId     String             @map("plan_id") @db.Uuid
  status     SubscriptionStatus @default(ACTIVE)
  startedAt  DateTime           @default(now()) @map("started_at")
  expiresAt  DateTime?          @map("expires_at")
  canceledAt DateTime?          @map("canceled_at")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  // Связи
  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan BillingPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([userId, status])
  @@map("user_subscriptions")
}
